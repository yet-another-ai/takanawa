[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.5
reloadable = true

[libraries]
linux.x86_64 = "res://addons/takanawa/bin/x86_64-unknown-linux-gnu/libtakanawa_gdextension.so"
macos = "res://addons/takanawa/bin/universal-apple-darwin/Takanawa.framework"
windows.x86_64 = "res://addons/takanawa/bin/x86_64-pc-windows-msvc/takanawa_gdextension.dll"
windows.x86_32 = "res://addons/takanawa/bin/i686-pc-windows-msvc/takanawa_gdextension.dll"
windows.arm64 = "res://addons/takanawa/bin/aarch64-pc-windows-msvc/takanawa_gdextension.dll"
android.arm64 = "res://addons/takanawa/bin/android/arm64-v8a/libtakanawa_gdextension.so"
android.arm32 = "res://addons/takanawa/bin/android/armeabi-v7a/libtakanawa_gdextension.so"
android.x86_64 = "res://addons/takanawa/bin/android/x86_64/libtakanawa_gdextension.so"
android.x86_32 = "res://addons/takanawa/bin/android/x86/libtakanawa_gdextension.so"
ios = "res://addons/takanawa/bin/ios/TakanawaGDExtension.xcframework"

[dependencies]
ios = {
  "res://addons/takanawa/bin/ios/TakanawaGDExtension.xcframework" : ""
}
