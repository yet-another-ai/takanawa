{
  "name": "takanawa-tauri",
  "version": "0.8.2",
  "description": "Tauri v2 bindings for Takanawa downloads.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yet-another-ai/takanawa",
    "directory": "packages/takanawa-tauri"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./src/testing.ts",
      "require": "./src/testing.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "import": "./dist/testing.mjs",
        "require": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "README.md",
    "dist",
    "Cargo.toml",
    "build.rs",
    "permissions",
    "src/**/*.rs"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "pnpm run build && node --test __test__/*.test.mjs"
  },
  "peerDependencies": {
    "@tauri-apps/api": ">=2 <3"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@types/node": "^24.10.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
