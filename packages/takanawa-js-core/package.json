{
  "name": "takanawa-js-core",
  "version": "0.5.1",
  "private": true,
  "description": "Internal shared JavaScript facade and target adapter contracts for Takanawa npm packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yet-another-ai/takanawa",
    "directory": "packages/takanawa-js-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "pnpm run build && node --test __test__/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
