{
  "name": "takanawa-capacitor",
  "version": "0.8.2",
  "description": "Capacitor bindings for Takanawa downloads on Android and iOS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yet-another-ai/takanawa",
    "directory": "packages/takanawa-capacitor"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./src/testing.ts",
      "require": "./src/testing.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "import": "./dist/testing.mjs",
        "require": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "README.md",
    "dist",
    "android/build.gradle",
    "android/src/main",
    "Package.swift",
    "ios/Sources",
    "ios/Takanawa.xcframework"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "pnpm run build && node --test __test__/*.test.mjs"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8 <9"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@types/node": "^24.10.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
