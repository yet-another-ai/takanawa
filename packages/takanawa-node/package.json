{
  "name": "takanawa-node",
  "version": "0.8.3",
  "description": "Node.js and Electron bindings for Takanawa powered by napi-rs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yet-another-ai/takanawa",
    "directory": "packages/takanawa"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "README.md",
    "dist",
    "index.js",
    "*.node"
  ],
  "scripts": {
    "build": "pnpm run build:native && pnpm run build:ts",
    "build:native": "napi build --platform --release",
    "build:ts": "tsdown",
    "dev:native": "napi build --platform",
    "dev:ts": "tsdown --watch",
    "test": "pnpm run build && node --test __test__/*.test.mjs"
  },
  "napi": {
    "name": "takanawa",
    "binaryName": "takanawa",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "@types/node": "^24.10.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
